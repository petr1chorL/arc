# Backend database. For a shared prototype, prefer managed PostgreSQL.
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Browser origins allowed to call this API. Use the exact Zeabur application domain.
ALLOWED_ORIGINS=https://your-app.zeabur.app

# Host headers accepted by the API service.
ALLOWED_HOSTS=your-app.zeabur.app,localhost,127.0.0.1

# Enable only when the API is served through HTTPS.
HSTS_ENABLED=true

# Reject requests with larger Content-Length before parsing JSON.
MAX_REQUEST_BODY_BYTES=1048576

# Basic per-client API rate limit. Keep an external access layer in front of public demos.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Keep real model keys in the deployment platform secret manager, not in Git.
MODEL_API_KEY=
MODEL_BASE_URL=https://api.deepseek.com
MODEL_ALLOWED_HOSTS=api.deepseek.com
MODEL_DEFAULT_MODEL=deepseek-v4-pro

# Future auth/session hardening defaults. These become relevant when login/session wiring is enabled.
COOKIE_SECURE=true
SESSION_IDLE_HOURS=8
SESSION_ABSOLUTE_DAYS=7

# 默认无需配置，API 使用 apps/api/data/arc_one.db。
# 切换 PostgreSQL 时，请通过系统环境变量设置完整 DATABASE_URL。
#
# PowerShell 形态示例：
# $env:DATABASE_URL="postgresql+psycopg://<user>:<password>@127.0.0.1:5432/arc_one"

# 当前项目默认使用 DeepSeek OpenAI-compatible API。
# 模型服务通过系统环境变量或本地 .env 配置，不要提交含真实密钥的 .env。
# $env:MODEL_API_KEY="<通过安全渠道提供的密钥>"
# $env:MODEL_BASE_URL="https://api.deepseek.com"
# $env:MODEL_DEFAULT_MODEL="deepseek-v4-pro"
# $env:MODEL_INPUT_USD_PER_MILLION_TOKENS="0"
# $env:MODEL_OUTPUT_USD_PER_MILLION_TOKENS="0"

# Backend database. For a shared prototype, prefer managed PostgreSQL.
ENVIRONMENT=production
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# Browser origins allowed to call this API. Keep this to the exact Pages URL and custom domains.
ALLOWED_ORIGINS=https://your-project.pages.dev,https://your-custom-domain.example

# Host headers accepted by the API service.
ALLOWED_HOSTS=your-api.example.com,localhost,127.0.0.1

# Enable only when the API is served through HTTPS.
HSTS_ENABLED=true

# Keep real model keys in the deployment platform secret manager, not in Git.
MODEL_API_KEY=
MODEL_BASE_URL=https://api.deepseek.com
MODEL_DEFAULT_MODEL=deepseek-v4-pro

# Future auth/session hardening defaults. These become relevant when login/session wiring is enabled.
COOKIE_SECURE=true
SESSION_IDLE_HOURS=8
SESSION_ABSOLUTE_DAYS=7
